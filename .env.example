# Application
APP_NAME=talkeo
ENV=development
LOG_LEVEL=INFO

# Database (Phase B+; unused in Phase A)
# DB_URL=postgresql+asyncpg://user:pass@localhost:5432/talkeo

# ── Providers ────────────────────────────────────────────────────────────────
# Each capability picks an adapter by name; which provider/model is used is
# config, never code (see docs/adrs/002 and 008). `fake` runs with no keys for
# local dev — it is rejected when ENV=staging|production.

# LLM — adapter `litellm` talks ONLY to the local LiteLLM proxy (ADR-008). The
# proxy (litellm_config.yaml) fronts every provider; the app selects a model by
# its `model_name` alias, so switching model OR provider is config, never code.
# Start it: set -a && source .env && set +a && uv run litellm --config litellm_config.yaml --port 4000
LLM_PROVIDER=fake
# LLM_PROVIDER=litellm
# LITELLM_BASE_URL=http://localhost:4000   # the proxy, NOT a provider endpoint
# LITELLM_API_KEY=sk-talkeo-local-dev      # app -> proxy auth; must == LITELLM_MASTER_KEY
# LITELLM_MASTER_KEY=sk-talkeo-local-dev   # the proxy reads this (general_settings.master_key)
# LLM_MODEL=groq/gpt-oss-120b              # default for /transform/*; an alias from litellm_config.yaml
# LLM_CONNECT_TIMEOUT=5                     # seconds; TCP handshake to the proxy
# LLM_READ_TIMEOUT=60                       # seconds; waiting on the model stream
#
# Per-feature MODEL overrides (translate / explain / improve). Each falls back to
# LLM_MODEL when unset. Values are aliases, so a feature can target a different
# provider — e.g. the same gpt-oss model on Fireworks instead of Groq:
# IMPROVE_LLM_MODEL=groq/gpt-oss-120b
# TRANSLATE_LLM_MODEL=fireworks/gpt-oss-120b
# EXPLAIN_LLM_MODEL=gemini/flash-lite
#
# Provider keys consumed by litellm_config.yaml (set the ones you use):
# GROQ_API_KEY=
# FIREWORKS_AI_API_KEY=
# GEMINI_API_KEY=

# TTS — /speak streams raw PCM (s16le, 24 kHz, mono) chunk-by-chunk (issue #22).
# TTS_PROVIDER picks the adapter:
#   livekit → a LiveKit TTS plugin engine chosen by TTS_ENGINE (issue #4)
#   fish    → native Fish Audio HTTP adapter (cloned/library voice)
TTS_PROVIDER=fake
# TTS_PROVIDER=livekit
# TTS_ENGINE=openai                      # openai | elevenlabs | cartesia | deepgram
# OPENAI_API_KEY=                        # required when TTS_ENGINE=openai
# ELEVENLABS_API_KEY=                    # required when TTS_ENGINE=elevenlabs
# CARTESIA_API_KEY=                      # required when TTS_ENGINE=cartesia
# DEEPGRAM_API_KEY=                      # required when TTS_ENGINE=deepgram
# TTS_VOICE=                             # optional; plugin default when unset
#                                        # (for deepgram, the voice is the model name)
# TTS_MODEL=                             # optional; plugin default when unset
# TTS_TIMEOUT=30                         # seconds; bounds the synthesize call
# TTS_PROVIDER=fish                      # native Fish Audio (no LiveKit plugin)
# FISH_API_KEY=                          # required when TTS_PROVIDER=fish
# FISH_VOICE=                            # reference_id of a cloned voice; default voice when unset
# FISH_MODEL=s2-pro                      # optional; Fish model header
# Output is WAV only for now (audio_format defaults to wav).

# STT — the voice agent transcribes in-session via a LiveKit STT plugin (#15).
# `STT_PROVIDER=fake` boots the agent keyless; `livekit` uses a real engine.
STT_PROVIDER=fake
# STT_PROVIDER=livekit

# ── Voice agent (LiveKit Agents worker, #15) ─────────────────────────────────
# Settings are named by surface so the agent can run different engines/models
# than the api's /speak. The agent reaches the same LiteLLM gateway as the api
# (ADR-008) via LiveKit's native openai.LLM plugin. Room credentials are required
# only to run the worker (console needs none); `console`/`dev` boot keyless when
# *_PROVIDER=fake.
# AGENT_STT_ENGINE=openai                # openai | elevenlabs — agent's STT plugin
# AGENT_STT_MODEL=                       # optional; plugin default when unset
# AGENT_STT_LANGUAGE=                    # optional language hint; plugin default when unset
# AGENT_TTS_ENGINE=                      # optional; falls back to TTS_ENGINE (cheaper voice for the agent)
# AGENT_LLM_MODEL=gemini/flash-lite      # optional alias; falls back to LLM_MODEL (use a fast non-reasoning model for voice)
# LIVEKIT_URL=ws://localhost:7880        # LiveKit server (Cloud or self-hosted)
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
